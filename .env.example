# Copy to .env and fill in values

# Required: a long random string (e.g. openssl rand -base64 32)
JWT_SECRET=your-secret-here

# Required: exactly 32 characters (AES-256 key)
TOTP_ENCRYPTION_KEY=12345678901234567890123456789012

# PostgreSQL connection string (used when running outside docker-compose)
DATABASE_URL=postgres://devops:devops@localhost:5432/devops?sslmode=disable

# Optional: override the postgres password used by docker-compose
POSTGRES_PASSWORD=devops

# Optional overrides
PORT=8080
PIPELINES_DIR=../pipelines
ALLOWED_ORIGIN=http://localhost:5173

# Optional: Read-only Personal Access Token for Git operations (GitHub/GitLab)
GIT_PAT=

# Session timeout in hours; default 24. Applies to post-TOTP / post-Entra JWTs.
# Frontend auto-logs the user out on expiry.
SESSION_TIMEOUT_HOURS=24

# Enable the interactive in-browser terminal (sidebar entry + /ws/terminal route).
# Default: true. Set to "false" to disable terminal containers and hide the UI.
TERMINAL_ENABLED=true

# Display name shown in the sidebar, browser title, login page, and TOTP issuer.
# Initial-seed only — once an admin saves a value via Settings UI, the DB wins
# and this env var is ignored on subsequent boots. Default: "Codeci".
APPLICATION_NAME=Codeci

# Microsoft Entra ID (Azure AD) SSO — initial seeds only.
# After first boot the values stored in app_settings (managed via the Settings UI)
# take over as the source of truth. Leave blank if Entra ID is not used.
ENTRA_CLIENT_ID=
ENTRA_TENANT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_REDIRECT_URL=http://localhost:8080/api/auth/entra/callback
