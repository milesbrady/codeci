#!/bin/sh
# Docker credential helper for ECR.
# Implements the credential helper protocol so docker can pull from ECR
# using the instance's IAM role without a separate login step.
case "$1" in
  get)
    SERVER=$(cat)
    if echo "$SERVER" | grep -q "public\.ecr\.aws"; then
      TOKEN=$(aws ecr-public get-login-password --region us-east-1)
    else
      REGION=$(echo "$SERVER" | sed -n 's|.*\.dkr\.ecr\.\([a-z0-9-]*\)\.amazonaws\.com.*|\1|p')
      [ -z "$REGION" ] && REGION="${AWS_DEFAULT_REGION:-us-east-1}"
      TOKEN=$(aws ecr get-login-password --region "$REGION")
    fi
    printf '{"Username":"AWS","Secret":"%s"}\n' "$TOKEN"
    ;;
  store|erase)
    ;;
  *)
    echo "Usage: docker-credential-ecr-login <get|store|erase>" >&2
    exit 1
    ;;
esac
